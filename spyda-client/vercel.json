{
  "buildCommand": "npm run build",
  "functions": {
    "api/generate.ts": {
      "maxDuration": 300
    },
    "api/analyze.ts": {
      "maxDuration": 60
    },
    "api/ocr.ts": {
      "maxDuration": 60
    },
    "api/validate-generation.ts": {
      "maxDuration": 60
    },
    "api/health.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/favicon.svg"
    },
    {
      "source": "/((?!api/|assets/|favicon.svg|manifest.webmanifest|sw.js|icons.svg).*)",
      "destination": "/index.html"
    }
  ]
}
